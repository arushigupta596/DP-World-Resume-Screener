SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# Embeddings (required for hybrid RAG search). Used by services/embedder.py.
# Without this key, uploads still succeed but skip embedding; scoring falls
# back to the full-CV prompt path, and the search bar returns 503.
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
