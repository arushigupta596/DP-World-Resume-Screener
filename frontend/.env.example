# Frontend .env
#
# Local dev: point at your local uvicorn backend.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_API_BASE=http://localhost:8000

# Production (Vercel): set VITE_API_BASE to an empty string so the frontend
# uses same-origin /api/* requests, which the vercel.json rewrite routes to
# the FastAPI ASGI handler at api/index.py.
#
# VITE_API_BASE=
